{
  "name": "est-super-gestao",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && tsx scripts/migrate-turso-all.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate-termo": "tsx --env-file=.env scripts/migrate-turso-termo.ts",
    "db:migrate-delivery-sync": "tsx --env-file=.env scripts/migrate-turso-delivery-sync.ts",
    "db:migrate-app-setting": "tsx --env-file=.env scripts/migrate-turso-app-setting.ts",
    "db:migrate-campaigns": "tsx --env-file=.env scripts/migrate-turso-campaigns.ts",
    "db:migrate-campaign-slug": "tsx --env-file=.env scripts/migrate-turso-campaign-slug.ts",
    "db:migrate-campaign-collab": "tsx --env-file=.env scripts/migrate-turso-campaign-collab.ts",
    "db:migrate-campaign-collab-drive": "tsx --env-file=.env scripts/migrate-turso-campaign-collab-drive.ts",
    "db:migrate-campaign-collab-briefing": "tsx --env-file=.env scripts/migrate-turso-collab-briefing.ts",
    "db:migrate-campaign-collab-request-share": "tsx --env-file=.env scripts/migrate-turso-collab-request-share.ts",
    "db:migrate-ambassador-quick-notes": "tsx --env-file=.env scripts/migrate-turso-ambassador-quick-notes.ts",
    "db:migrate-ambassador-social-name": "tsx --env-file=.env scripts/migrate-turso-ambassador-social-name.ts",
    "db:migrate-ambassador-report-slug": "tsx --env-file=.env scripts/migrate-turso-ambassador-report-slug.ts",
    "db:migrate-contatos-parcerias": "tsx --env-file=.env scripts/migrate-turso-contatos-parcerias.ts",
    "db:migrate-respostas-sync": "tsx --env-file=.env scripts/migrate-turso-respostas-sync.ts",
    "db:migrate-all": "tsx scripts/migrate-turso-all.ts",
    "fix:contatos-trabalhando": "tsx --env-file=.env scripts/fix-contatos-trabalhando.ts",
    "seed:ambassador-reports": "tsx --env-file=.env scripts/seed-ambassador-report-slugs.ts",
    "share:amanda-pedido2": "tsx --env-file=.env scripts/share-amanda-pedido2.ts",
    "db:studio": "prisma studio",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "verify": "tsx scripts/verify-db.ts",
