    "test:gmail": "node --env-file=.env --import tsx scripts/test-gmail.ts",
    "gmail:auth": "python3 scripts/gmail-auth.py",
    "test:sheets": "tsx --env-file=.env scripts/test-sheets.ts",
    "db:clear-deliveries": "tsx --env-file=.env scripts/clear-deliveries.ts",
    "recalc:entregas": "tsx --env-file=.env scripts/recalc-all-entregas.ts",
    "import:entregas-csv": "tsx --env-file=.env scripts/import-entregas-csv.ts",
    "fix:delivery-dates": "tsx --env-file=.env scripts/fix-delivery-dates.ts",
    "sync:entregas": "tsx --env-file=.env scripts/sync-entregas.ts",
    "sync:respostas": "tsx --env-file=.env scripts/sync-respostas.ts",
    "validate:respostas": "tsx --env-file=.env scripts/validate-respostas-sync.ts",
    "setup:cloud-secrets": "tsx --env-file=.env scripts/setup-cloud-secrets.ts",
    "preview:respostas": "tsx --env-file=.env scripts/preview-respostas-headers.ts",
    "preview:entregas": "tsx --env-file=.env scripts/preview-entregas-sync.ts",
    "import:xlsx": "tsx scripts/import-xlsx.ts"
